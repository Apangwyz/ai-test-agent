# Server Configuration
FLASK_APP=app.py
FLASK_ENV=development
PORT=5001

# Database Configuration
DATABASE_URL=postgresql://admin:password@localhost:5432/example_db

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-here
JWT_ACCESS_TOKEN_EXPIRES=3600

# AI Model Configuration
OPENAI_API_KEY=your-openai-api-key
MODEL_NAME=gpt-3.5-turbo

# Qwen Model Configuration
QWEN_API_KEY=your-qwen-api-key
QWEN_MODEL_NAME=qwen-turbo
QWEN_API_BASE=https://api.dashscope.aliyuncs.com/api/v1
QWEN_TIMEOUT=60

# AI Model Type Configuration
AI_MODEL_TYPE=qwen  # Options: qwen, openai

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=app.log

# Fix PYTHONPATH issue - unset to avoid conflicts with system Python
PYTHONPATH=
